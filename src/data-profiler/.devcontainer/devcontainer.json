{
    "name": "WB Data Profiler",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "forwardPorts": [8080],
    "postCreateCommand": "cd /app && pip install --no-cache-dir -r requirements.txt",
    "postStartCommand": "cd /app && ./start.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}
