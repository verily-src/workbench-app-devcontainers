# FastOMOP Docker Deployment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# OLLAMA CONFIGURATION (GPU Node)
# ============================================
# Replace with your GPU node IP address
# Format: http://<gpu-node-ip>:8002
OLLAMA_HOST=http://10.211.114.XXX:8002

# ============================================
# OMOP DATABASE CONFIGURATION
# ============================================
# Option A: Local DuckDB (for testing/small datasets)
DB_PATH=/app/data/omop.duckdb

# Option B: PostgreSQL (for production - uncomment and configure)
# DB_HOST=postgres-host
# DB_PORT=5432
# DB_NAME=omop_cdm
# DB_USER=omop_user
# DB_PASSWORD=secure_password

# ============================================
# LANGFUSE OBSERVABILITY (Optional)
# ============================================
# Leave empty to disable observability
# Get free credentials at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# MILVUS VECTOR DATABASE (Optional)
# ============================================
# Only needed if using Milvus instead of LanceDB
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=fastomop_vocab

# ============================================
# WEB INTERFACE CONFIGURATION
# ============================================
# Port for web interface (default: 7777)
WEB_PORT=7777

# Host binding (0.0.0.0 for all interfaces, localhost for local only)
WEB_HOST=0.0.0.0
