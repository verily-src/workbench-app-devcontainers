# CouchDB Configuration
DB_LOCATION=./couchdb
COUCHDB_USER=admin
COUCHDB_PASSWORD=password
COUCH_PORT=5984
COUCH_DB=image_comparator

# Flask Application Settings
FLASK_APP=OPTIMEyes
IMAGE_COMPARATOR_DATA=/workspace/data
DNS=0.0.0.0
SSL=False
DB_PORT=5984
HTTP_PORT=80
DEPLOY=PROD
ADMIN_PARTY=False
SECRET_KEY=dev-secret-key-change-in-production

# MONAI Label Configuration (optional)
MONAI_LABEL_ENV=development